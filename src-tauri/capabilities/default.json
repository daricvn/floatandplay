{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for FloatPiP",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/yt-dlp",
          "sidecar": true,
          "args": true
        }
      ]
    },
    "global-shortcut:allow-is-registered",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "global-shortcut:allow-unregister-all",
    "store:allow-clear",
    "store:allow-delete",
    "store:allow-entries",
    "store:allow-get",
    "store:allow-keys",
    "store:allow-load",
    "store:allow-reset",
    "store:allow-save",
    "store:allow-set",
    "store:allow-values",
    "dialog:allow-open",
    "dialog:allow-save",
    "deep-link:default",
    "core:window:allow-hide",
    "core:window:allow-start-dragging"
  ]
}
